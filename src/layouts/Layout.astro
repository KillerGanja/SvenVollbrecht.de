---
import "../styles/global.css";
import Header from "../components/Header.astro";
import ScreenSizeIndicator from "../components/ScreenSizeIndicator.astro";
import SEO from "../components/SEO.astro";
import { t, getRelativeLocaleUrl } from "../utils/i18n";
import settings from "../content/ui/settings.json";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  type?: "website" | "article" | "profile";
  lang?: string;
}

const {
  title = "Sven Vollbrecht",
  description = "Sven Vollbrecht (geboren in West-Berlin) ist ein deutscher Konzeptkünstler. Er arbeitet mit Installationen, Videoarbeiten und partizipativen Formaten.",
  image = "/favicon.svg",
  type = "website",
} = Astro.props;
const { lang } = Astro.params as { lang: string };
const locale = lang || "de";

// Generate absolute URL for canonical link
const canonicalURL = new URL(Astro.url.pathname, Astro.site || 'https://svenvollbrecht.de');

// Generate hreflang URLs
const pathname = Astro.url.pathname;
const baseSlug = pathname.replace(/^\/(de|en)/, '') || '/';
const siteUrl = Astro.site?.toString().replace(/\/$/, '') || 'https://svenvollbrecht.de';

const hreflang = [
  { lang: 'de', href: `${siteUrl}/de${baseSlug}` },
  { lang: 'en', href: `${siteUrl}/en${baseSlug}` },
  { lang: 'x-default', href: `${siteUrl}/de${baseSlug}` },
];
---

<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <SEO
      title={title}
      description={description}
      image={image}
      canonicalUrl={canonicalURL.toString()}
      type={type}
      hreflang={hreflang}
    />
    <slot name="head" />
    <style
      is:inline
      set:html={`
      :root {
        --prose-line-height: ${settings.prose_line_height};
        --prose-paragraph-spacing: ${settings.prose_paragraph_spacing};
        --prose-font-size: ${settings.prose_font_size};
        --metadata-font-size: ${settings.metadata_font_size};
      }
    `}
    ></style>
  </head>
  <body class="flex min-h-screen flex-col bg-white text-gray-900 antialiased">
    <ScreenSizeIndicator />
    <Header lang={locale} />

    <main
      class="mx-auto w-full max-w-screen-2xl flex-grow px-4 py-10 sm:px-8 lg:px-16"
    >
      <slot />
    </main>

    <footer
      class="sticky bottom-0 z-40 border-t border-gray-100 bg-white/90 py-6 text-sm text-gray-500 backdrop-blur-md"
    >
      <div
        class="mx-auto grid max-w-screen-2xl grid-cols-1 gap-4 px-4 sm:grid-cols-3 sm:px-8 lg:px-16"
      >
        <!-- Linker Bereich (leer für Zentrierung der Mitte) -->
        <div class="hidden sm:block"></div>

        <!-- Mitte: Copyright -->
        <div class="text-center">
          &copy; {new Date().getFullYear()} Sven Vollbrecht
        </div>

        <!-- Rechts: Links -->
        <div class="flex justify-center gap-6 sm:justify-end">
          <a
            href={getRelativeLocaleUrl(locale, "/impressum")}
            class="transition-colors hover:text-gray-900"
            >{t("nav_impressum", locale)}</a
          >
          <a
            href={getRelativeLocaleUrl(locale, "/privacy")}
            class="transition-colors hover:text-gray-900"
            >{t("nav_privacy", locale)}</a
          >
        </div>
      </div>
    </footer>
  </body>
</html>

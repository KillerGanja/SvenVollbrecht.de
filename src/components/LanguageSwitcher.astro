---
interface Props {
    lang?: string;
}

const { lang: propLang } = Astro.props;
const { lang: paramsLang } = Astro.params;
const currentLang = propLang || paramsLang || "de";
const pathname = Astro.url.pathname;

// Generate target URL
let targetUrl;
if (currentLang === "de") {
    // Current is de, target is en
    if (pathname === "/" || pathname === "/de") {
        targetUrl = "/en";
    } else {
        // Just prefix with /en if it doesn't have it
        targetUrl = pathname.startsWith("/en") ? pathname : `/en${pathname}`;
    }
} else {
    // Current is en, target is de
    if (pathname === "/en") {
        targetUrl = "/";
    } else {
        // Remove /en prefix
        targetUrl = pathname.replace(/^\/en/, "") || "/";
    }
}
---

<div
    class="flex items-center gap-2 text-xs font-light tracking-widest uppercase border border-red-500"
>
    <a
        href={currentLang === "de" ? "#" : targetUrl}
        class={`transition-colors hover:text-gray-900 ${currentLang === "de" ? "text-gray-900 font-medium" : "text-gray-400"}`}
        aria-current={currentLang === "de" ? "page" : undefined}
    >
        de
    </a>
    <span class="text-gray-200">/</span>
    <a
        href={currentLang === "en" ? "#" : targetUrl}
        class={`transition-colors hover:text-gray-900 ${currentLang === "en" ? "text-gray-900 font-medium" : "text-gray-400"}`}
        aria-current={currentLang === "en" ? "page" : undefined}
    >
        en
        <span class="sr-only">Language Switcher</span>
        <span>DEBUG_SWITCHER</span>
    </a>

    <style>
        a {
            text-decoration: none;
        }
    </style>
</div>

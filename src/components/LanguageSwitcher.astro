---
interface Props {
    lang?: string;
}

const { lang: propLang } = Astro.props;
const { lang: paramsLang } = Astro.params;
const currentLang = propLang || paramsLang || "de";
const pathname = Astro.url.pathname;

// Generate target URL
let targetUrl = "/";
if (currentLang === "de") {
    // Current is de, target is en
    if (pathname === "/" || pathname === "/de") {
        targetUrl = "/en";
    } else {
        targetUrl = pathname.startsWith("/en") ? pathname : `/en${pathname}`;
    }
} else {
    // Current is en, target is de
    if (pathname === "/en") {
        targetUrl = "/";
    } else {
        targetUrl = pathname.replace(/^\/en/, "") || "/";
    }
}
---

<div
    class="flex items-center gap-2 text-xs font-light tracking-widest uppercase"
>
    {
        currentLang === "de" ? (
            <span class="text-gray-900 font-medium cursor-default">de</span>
        ) : (
            <a
                href={targetUrl}
                class="text-gray-400 hover:text-gray-900 transition-colors"
            >
                de
            </a>
        )
    }
    <span class="text-gray-200">/</span>
    {
        currentLang === "en" ? (
            <span class="text-gray-900 font-medium cursor-default">en</span>
        ) : (
            <a
                href={targetUrl}
                class="text-gray-400 hover:text-gray-900 transition-colors"
            >
                en
            </a>
        )
    }
</div>

<style>
    a,
    span {
        text-decoration: none;
    }
</style>

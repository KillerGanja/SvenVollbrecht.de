---
import Layout from "../../layouts/Layout.astro";
import type { MarkdownInstance } from "astro";
import type { WorkFrontmatter } from "../../types";

// Load entries
const worksEntries = Object.values(
    import.meta.glob<MarkdownInstance<WorkFrontmatter>>(
        "../../content/works/de/*.md",
        {
            eager: true,
        },
    ),
);

// Filter and map
const works = worksEntries
    .map((entry) => ({
        ...entry.frontmatter,
        url: `/works/${entry.frontmatter.slug}/`,
    }))
    .sort((a, b) => {
        const orderA = a.order ?? 9999;
        const orderB = b.order ?? 9999;
        if (orderA !== orderB) return orderA - orderB;
        return (Number(b.year) || 0) - (Number(a.year) || 0);
    });

const title = "Arbeiten – Übersicht";
---

<Layout title={title}>
    <h1 class="mb-12 text-3xl font-light tracking-wide text-gray-900">
        Arbeiten
    </h1>

    {
        works.length === 0 ? (
            <p class="text-gray-500">Noch keine Werke angelegt.</p>
        ) : (
            <div class="grid grid-cols-2 gap-4 md:gap-8 md:grid-cols-3 xl:grid-cols-4">
                {works.map((work) => (
                    <a href={work.url} class="group block">
                        <div class="aspect-[4/5] overflow-hidden bg-gray-100">
                            {work.cover_image ? (
                                <img
                                    src={work.cover_image}
                                    alt={work.title}
                                    class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                                />
                            ) : (
                                <div class="flex h-full w-full items-center justify-center text-gray-400">
                                    Kein Bild
                                </div>
                            )}
                        </div>
                    </a>
                ))}
            </div>
        )
    }
</Layout>

---
import Layout from "../../layouts/Layout.astro";
import { t } from "../../utils/i18n";
import { marked } from "marked";

export function getStaticPaths() {
    return [{ params: { lang: "de" } }, { params: { lang: "en" } }];
}

const { lang } = Astro.params;

// Load static data
const homeEntries = import.meta.glob<any>("../../content/pages/home.md", {
    eager: true,
});
const homeEntry = Object.values(homeEntries)[0];

if (!homeEntry) {
    return new Response("Home content missing at ../../content/pages/home.md", {
        status: 404,
    });
}

const { frontmatter } = homeEntry;
const title = `Sven Vollbrecht – ${t("nav_home", lang) || "Startseite"}`;
const body = frontmatter[`body_${lang}`] || frontmatter.body_de || "";
// Only parse if body is not empty to avoid errors
const htmlContent = body ? marked.parse(body) : "";

// Detect if media is a video
const isVideo = frontmatter.image
    ? frontmatter.image.match(/\.(mp4|webm|ogv)$|youtube\.com|vimeo\.com/i)
    : false;
---

<Layout title={title}>
    <Fragment slot="head">
        <script type="application/ld+json" set:html={JSON.stringify({
          "@context": "https://schema.org",
          "@type": "Person",
          "name": "Sven Vollbrecht",
          "alternateName": "Sven Vollbrecht",
          "url": "https://svenvollbrecht.de",
          "image": "https://upload.wikimedia.org/wikipedia/commons/a/a2/Sven_Vollbrecht_vor_seinem_Werk_SIGNS.jpg",
          "jobTitle": "Konzeptkünstler",
          "description": "Sven Vollbrecht ist ein deutscher Konzeptkünstler, der mit Installationen und partizipativen Formaten arbeitet.",
          "sameAs": [
            "https://de.wikipedia.org/wiki/Sven_Vollbrecht",
            "https://www.instagram.com/thevollbrecht",
            "https://www.youtube.com/@thevollbrecht",
            "https://artfacts.net/artist/sven-vollbrecht/543167"
          ]
        })} />
    </Fragment>
    <div class="mt-16 text-center">
        {
            frontmatter.image &&
                (isVideo ? (
                    <div class="mx-auto mb-8 max-h-[70vh] w-full max-w-4xl">
                        <video
                            src={frontmatter.image}
                            autoplay
                            loop
                            muted
                            playsinline
                            class="mx-auto max-h-[70vh] w-auto max-w-full object-contain"
                        />
                    </div>
                ) : (
                    <img
                        src={frontmatter.image}
                        alt="Sven Vollbrecht"
                        class="mx-auto mb-8 max-h-[70vh] w-auto max-w-full object-contain"
                    />
                ))
        }
        {
            htmlContent && (
                <div class="prose prose-gray mx-auto" set:html={htmlContent} />
            )
        }
    </div>
</Layout>

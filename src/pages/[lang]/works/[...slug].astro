---
import Layout from "../../../layouts/Layout.astro";
import { t } from "../../../utils/i18n";
import { marked } from "marked";
import WorkSlideshow from "../../../components/WorkSlideshow.astro";

export async function getStaticPaths() {
    const entries = Object.values(
        import.meta.glob<any>("../../../content/works/*.md", {
            eager: true,
        }),
    );

    const languages = ["de", "en"];

    return languages.flatMap((lang) => {
        return entries.map((entry) => ({
            params: {
                lang,
                slug: entry.frontmatter.slug,
            },
            props: { entry },
        }));
    });
}

const { lang, slug } = Astro.params;
const { entry } = Astro.props;
const { frontmatter } = entry;

// Determine localized content
const title = frontmatter.title || ""; // Title is shared
const materials =
    frontmatter[`materials_${lang}`] || frontmatter.materials_de || "";
const dimensions =
    frontmatter[`dimensions_${lang}`] || frontmatter.dimensions_de || "";
const description =
    frontmatter[`description_${lang}`] || frontmatter.description_de || "";

const htmlContent = marked.parse(description);
---

<Layout title={title}>
    <div class="mx-auto max-w-screen-xl">
        <WorkSlideshow images={frontmatter.gallery_images} title={title} />

        <div class="mt-12 grid grid-cols-1 gap-12 lg:grid-cols-3">
            <div class="lg:col-span-2">
                <div
                    class="prose prose-gray max-w-none"
                    set:html={htmlContent}
                />
            </div>

            <div
                class="space-y-6 text-sm text-gray-600 border-l border-gray-100 pl-8"
            >
                {
                    frontmatter.year && (
                        <div>
                            <span class="block font-medium text-gray-900">
                                {t("field_year", lang) || "Jahr"}
                            </span>
                            <span>{frontmatter.year}</span>
                        </div>
                    )
                }
                {
                    materials && (
                        <div>
                            <span class="block font-medium text-gray-900">
                                {t("field_materials", lang) || "Material"}
                            </span>
                            <span>{materials}</span>
                        </div>
                    )
                }
                {
                    dimensions && (
                        <div>
                            <span class="block font-medium text-gray-900">
                                {t("field_dimensions", lang) || "Maße"}
                            </span>
                            <span>{dimensions}</span>
                        </div>
                    )
                }
                {
                    frontmatter.series && (
                        <div>
                            <span class="block font-medium text-gray-900">
                                {t("field_series", lang) || "Serie"}
                            </span>
                            <span>{frontmatter.series}</span>
                        </div>
                    )
                }
            </div>
        </div>
    </div>
</Layout>

---
import Layout from "../../layouts/Layout.astro";
import { t } from "../../utils/i18n";
import { marked } from "marked";

export async function getStaticPaths() {
    const pages = ["about", "contact", "impressum", "privacy"];
    const languages = ["de", "en"];

    return languages.flatMap((lang) => {
        return pages.map((slug) => ({
            params: { lang, slug },
        }));
    });
}

const { lang, slug } = Astro.params;

// Load all pages
const pageEntries = import.meta.glob<any>("../../../content/pages/*.md", {
    eager: true,
});
const pageEntry = Object.values(pageEntries).find(
    (p) => p.frontmatter.slug === slug,
);

if (!pageEntry) {
    return new Response(`Page not found: ${slug}`, { status: 404 });
}

const { frontmatter } = pageEntry;
const title = frontmatter.title || t(`nav_${slug}`, lang);
const body = frontmatter[`body_${lang}`] || frontmatter.body_de || "";
const htmlContent = marked.parse(body);
---

<Layout title={title}>
    <div class="mx-auto max-w-prose">
        <h1 class="mb-12 text-3xl font-light tracking-wide text-gray-900">
            {title}
        </h1>

        <div class="prose prose-gray max-w-none" set:html={htmlContent} />
    </div>
</Layout>

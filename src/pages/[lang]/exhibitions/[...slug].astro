---
import Layout from "../../../layouts/Layout.astro";
import { t } from "../../../utils/i18n";
import { marked } from "marked";
import ImageGallery from "../../../components/ImageGallery.astro";

export async function getStaticPaths() {
    const entries = Object.values(
        import.meta.glob<any>("../../../content/exhibitions/*.md", {
            eager: true,
        }),
    );

    const languages = ["de", "en"];

    return languages.flatMap((lang) => {
        return entries.map((entry) => ({
            params: {
                lang,
                slug: entry.frontmatter.slug,
            },
            props: { entry },
        }));
    });
}

const { lang, slug } = Astro.params;
const { entry } = Astro.props;
const { frontmatter } = entry;

const title = frontmatter.title || "";
const venue = frontmatter[`venue_${lang}`] || frontmatter.venue_de || "";
const city = frontmatter[`city_${lang}`] || frontmatter.city_de || "";
const period = frontmatter[`period_${lang}`] || frontmatter.period_de || "";
const description =
    frontmatter[`description_${lang}`] || frontmatter.description_de || "";

const htmlContent = marked.parse(description);
---

<Layout title={title}>
    <div class="mx-auto max-w-screen-xl">
        <h1 class="mb-4 text-3xl font-light tracking-wide text-gray-900">
            {title}
        </h1>

        <div class="mb-12 space-y-1 text-sm text-gray-600">
            {venue && <p class="font-medium text-gray-900">{venue}</p>}
            {
                (city || period) && (
                    <p>{[city, period].filter(Boolean).join(", ")}</p>
                )
            }
        </div>

        <div class="prose prose-gray max-w-3xl mb-16" set:html={htmlContent} />

        {
            frontmatter.gallery_images && (
                <ImageGallery images={frontmatter.gallery_images} />
            )
        }
    </div>
</Layout>

---
import Layout from "../../../layouts/Layout.astro";
import { t } from "../../../utils/i18n";

export function getStaticPaths() {
    return [{ params: { lang: "de" } }, { params: { lang: "en" } }];
}

const { lang } = Astro.params;

const entries = Object.values(
    import.meta.glob<any>("../../../content/exhibitions/de/*.md", {
        eager: true,
    }),
);

const exhibitions = entries
    .map((entry) => ({
        ...entry.frontmatter,
        title: t(entry.frontmatter.translation_key_title, lang),
        url: `/${lang}/exhibitions/${entry.frontmatter.slug}/`,
    }))
    .sort((a, b) => {
        const orderA = a.order ?? 9999;
        const orderB = b.order ?? 9999;
        if (orderA !== orderB) return orderA - orderB;
        return (Number(b.year) || 0) - (Number(a.year) || 0);
    });

const title = t("nav_exhibitions", lang);
---

<Layout title={title}>
    <h1 class="mb-12 text-3xl font-light tracking-wide text-gray-900">
        {title}
    </h1>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-12">
        {
            exhibitions.map((exh) => (
                <a href={exh.url} class="group block">
                    <div class="aspect-video overflow-hidden bg-gray-100 mb-4">
                        <img
                            src={exh.cover_image}
                            alt={exh.title}
                            class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105"
                        />
                    </div>
                    <h2 class="text-xl font-medium text-gray-900 group-hover:text-blue-600">
                        {exh.title}
                    </h2>
                    <p class="text-sm text-gray-500">
                        {exh.year} — {exh.city}
                    </p>
                </a>
            ))
        }
    </div>
</Layout>

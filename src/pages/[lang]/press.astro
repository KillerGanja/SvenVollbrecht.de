---
import Layout from "../../layouts/Layout.astro";
import { t } from "../../utils/i18n";
import { marked } from "marked";

export function getStaticPaths() {
    return [{ params: { lang: "de" } }, { params: { lang: "en" } }];
}

const { lang } = Astro.params;

const entries = Object.values(
    import.meta.glob<any>("../../content/press/*.md", { eager: true }),
);

// Process and sort items by date
const processedItems = entries
    .map((entry) => {
        const fm = entry.frontmatter;
        const itemDate = fm.date ? new Date(fm.date) : new Date(0);

        return {
            ...fm,
            year: itemDate.getFullYear(),
            formattedDate: itemDate.toLocaleDateString("de-DE", {
                month: "2-digit",
                year: "numeric",
            }),
            // Localized resolution
            displayTitle: fm[`title_${lang}`] || fm.title || "",
            displayAuthor: fm[`author_${lang}`] || fm.author_de || "",
            displayMedium: fm.medium || "",
            displayLang: fm.lang_label ? `(${fm.lang_label})` : "",
        };
    })
    .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

// Group items by year
const groupedPress = processedItems.reduce(
    (acc, item) => {
        const year = item.year;
        if (!acc[year]) {
            acc[year] = [];
        }
        acc[year].push(item);
        return acc;
    },
    {} as Record<number, typeof processedItems>,
);

const sortedYears = Object.keys(groupedPress)
    .map(Number)
    .sort((a, b) => b - a);

const title = t("nav_press", lang);
const labelBy = t("label_by", lang) || "von";
---

<Layout title={title}>
    <h1 class="mb-12 text-3xl font-light tracking-wide text-gray-900">
        {title}
    </h1>

    <div class="space-y-16 max-w-4xl">
        {
            sortedYears.map((year) => (
                <section>
                    <h2 class="text-2xl font-light text-gray-900 mb-8">
                        {year}
                    </h2>
                    <div class="space-y-6">
                        {groupedPress[year].map((item) => (
                            <div class="text-lg text-gray-800 leading-relaxed font-light">
                                <span class="group">
                                    {item.url ? (
                                        <a
                                            href={item.url}
                                            target="_blank"
                                            rel="noopener noreferrer"
                                            class="hover:underline"
                                        >
                                            {item.displayTitle}
                                        </a>
                                    ) : (
                                        item.displayTitle
                                    )}
                                </span>

                                {item.displayLang && (
                                    <span class="text-gray-500 ml-1">
                                        {item.displayLang}
                                    </span>
                                )}

                                {item.displayAuthor && (
                                    <span class="text-gray-500">
                                        {" "}
                                        {labelBy} {item.displayAuthor}
                                    </span>
                                )}

                                {item.displayMedium && (
                                    <span class="text-gray-400">
                                        {" "}
                                        – {item.displayMedium}
                                    </span>
                                )}

                                <span class="text-gray-400 ml-1">
                                    , {item.formattedDate}
                                </span>
                            </div>
                        ))}
                    </div>
                </section>
            ))
        }
    </div>
</Layout>
